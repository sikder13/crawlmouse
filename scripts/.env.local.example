# Local-only admin credentials for scripts/ — copy this file to scripts/.env.local
# and fill in real values. scripts/.env.local is gitignored (matches root .gitignore).
#
# Generate a Personal Access Token at:
#   https://supabase.com/dashboard/account/tokens
# Name it something like "crawlmouse-config-token". Treat it like a password —
# it has full admin power over every project in your Supabase account.

SUPABASE_ACCESS_TOKEN=
