# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Inngest
INNGEST_SIGNING_KEY=
INNGEST_EVENT_KEY=

# Resend
RESEND_API_KEY=
# Resend webhook signing secret (Resend dashboard → Webhooks → your endpoint)
RESEND_WEBHOOK_SECRET=

# Stripe (Plan 4) — get keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID_PRO_MONTHLY=
STRIPE_PRICE_ID_PRO_YEARLY=
# Asserts the mode the active Stripe key must be in for the reconcile cron ('true' in prod).
# Unset = no assertion (dev). Mismatch → the reconcile run is refused, never nulls pro_until.
STRIPE_RECONCILE_LIVEMODE=

# Cloudflare Turnstile
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Observability
# PostHog is reverse-proxied through /ingest (see next.config.mjs rewrites). Leave the host unset
# to use the proxy (recommended in prod — survives ad-blockers); set an absolute host only for
# local debugging.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Base URL (for absolute links in emails)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Admin
# Bearer token for service ops routes (e.g. POST /api/admin/takedown/process). Long random string.
ADMIN_SECRET=
